*.py[cod]
*$py.class
__pycache__/
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editors and operating systems
.vscode/
.idea/
.DS_Store
Thumbs.db
